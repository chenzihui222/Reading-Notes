# VC Investment Heat Tracker

## Git Ignore File

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
ENV/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Data files (large files)
data/*.json
data/*.csv
!data/.gitkeep

# Output files
output/charts/*.png
output/charts/*.html
output/reports/*.html
!output/charts/.gitkeep
!output/reports/.gitkeep

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Jupyter Notebook
.ipynb_checkpoints/

# Environment variables
.env
.env.local
