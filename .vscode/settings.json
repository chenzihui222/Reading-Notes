{
  // GitLens - 在资源管理器中显示Git信息
  "gitlens.currentLine.enabled": true,
  "gitlens.currentLine.pullRequests.enabled": false,
  "gitlens.statusBar.enabled": true,
  "gitlens.statusBar.alignment": "left",
  "gitlens.hovers.enabled": true,
  "gitlens.hovers.currentLine.enabled": true,
  "gitlens.hovers.currentLine.over": "annotation",

  // GitLens - 侧边栏显示分支（简化配置）
  "gitlens.views.branches.enabled": true,
  "gitlens.views.branches.showBranchComparison": false,
  "gitlens.views.branches.pullRequests.enabled": false,
  "gitlens.views.branches.showStashes": false,
  "gitlens.views.branches.showTags": false,
  "gitlens.views.branches.showRemotes": false,
  "gitlens.views.branches.showRemoteBranches": false,
  "gitlens.views.branches.showWorktrees": false,
  "gitlens.views.branches.showContributors": false,

  // GitLens - 文件历史
  "gitlens.views.fileHistory.enabled": false,
  "gitlens.views.lineHistory.enabled": false,

  // 在状态栏显示当前分支（VS Code 内置）
  "git.enableStatusBarSync": true,

  // 装饰 - 在文件资源管理器中显示Git状态
  "git.decorations.enabled": true,
  "explorer.decorations.badges": true,
  "explorer.decorations.colors": true,

  // 简化 GitLens 侧边栏布局
  "gitlens.views.repositories.enabled": false,
  "gitlens.views.commitGraph.enabled": false,
  "gitlens.views.searchAndCompare.enabled": false,
  "gitlens.views.drafts.enabled": false
}
